# ========================================================================
# BUTTONS CONFIGURATION
# Physical and touch button inputs with actions
# ========================================================================

# Touch sensor configuration
esp32_touch:
  measurement_duration: 5ms  # Increased for better stability through enclosure
  # Enable debug logging to see actual touch values
  setup_mode: false  # Disable after calibration

# Button sensors
binary_sensor:
  # Physical reset button
  - platform: gpio
    pin:
      number: GPIO5
      mode: INPUT_PULLUP
      inverted: true
    name: "Reset button"
    icon: mdi:restart
    web_server:
      sorting_group_id: grp_hidden
    on_click:
      # Long press (5-60 seconds) triggers factory reset
      - min_length: 5s
        max_length: 60s
        then:
          - rtttl.play: "beep:d=4,o=5,b=120:16a"
          - lambda: |-

              id(my_display).fill(COLOR_OFF);
              id(my_display).print(30, 60, id(font1), "Factory Reset...");
              id(my_display).print(30, 80, id(font1), "Please wait...");
              id(my_display).update();
          - delay: 2s
          - switch.turn_on: do_factory_reset

  # Touch button 1
  - platform: esp32_touch
    name: "Button 1"
    icon: mdi:numeric-1-circle
    id: button_1
    pin: GPIO10
    web_server:
      sorting_group_id: grp_extras
    threshold: 35000  # Adjusted for enclosure
    on_press:
      then:
        - rtttl.play: "btn1:d=8,o=5,b=200:c"

    filters:
      - delayed_on: 50ms  # Increased debounce
      - delayed_off: 100ms

  # Touch button 2
  - platform: esp32_touch
    name: "Button 2"
    icon: mdi:numeric-2-circle
    id: button_2
    pin: GPIO11
    web_server:
      sorting_group_id: grp_extras
    threshold: 35000  # Adjusted for enclosure
    on_press:
      then:
        - rtttl.play: "btn2:d=8,o=5,b=200:d"

    filters:
      - delayed_on: 50ms  # Increased debounce
      - delayed_off: 100ms

  # Touch button 3
  - platform: esp32_touch
    name: "Button 3"
    icon: mdi:numeric-3-circle
    id: button_3
    pin: GPIO12
    web_server:
      sorting_group_id: grp_extras
    threshold: 35000  # Adjusted for enclosure
    on_press:
      then:
        - rtttl.play: "btn3:d=8,o=5,b=200:e"

    filters:
      - delayed_on: 50ms  # Increased debounce
      - delayed_off: 100ms

  # Touch button 4
  - platform: esp32_touch
    name: "Button 4"
    icon: mdi:numeric-4-circle
    id: button_4
    pin: GPIO13
    web_server:
      sorting_group_id: grp_extras
    threshold: 35000  # Fallback threshold
    on_press:
      then:
        - rtttl.play: "btn4:d=8,o=5,b=200:g"
        - lambda: |-
            ESP_LOGI("touch", "Button 4 pressed - Raw: %.0f", id(touch_value_4).state);

    filters:
      - lambda: |-
          static float baseline = NAN;
          static int init_count = 0;

          // Initialize baseline over first 50 readings
          if (isnan(baseline) || init_count < 50) {
            if (isnan(baseline)) baseline = x;
            baseline = baseline * 0.9 + x * 0.1;
            init_count++;
            ESP_LOGD("touch", "Button 4 - Initializing baseline: %.0f (reading #%d)", baseline, init_count);
            return false;
          }

          // Slow baseline adaptation (ignores touches)
          if (x > baseline - 300) {
            baseline = baseline * 0.995 + x * 0.005;
          }

          // Log every 100th reading
          static int log_counter = 0;
          if (++log_counter >= 100) {
            ESP_LOGI("touch", "Button 4 - Value: %.0f, Baseline: %.0f, Delta: %.0f",
                     x, baseline, baseline - x);
            log_counter = 0;
          }

          // Trigger if 500+ below baseline
          bool touched = (x < baseline - 500);
          if (touched) {
            ESP_LOGI("touch", "Button 4 TOUCHED - Value: %.0f, Baseline: %.0f, Delta: %.0f",
                     x, baseline, baseline - x);
          }
          return touched;
      - delayed_on: 50ms
      - delayed_off: 100ms

# Diagnostic sensors to show actual touch values
sensor:
  - platform: esp32_touch
    name: "Button 1 Touch Value"
    pin: GPIO10
    id: touch_value_1
    filters:
      - median:
          window_size: 7  # More samples for stability
          send_every: 5
      - sliding_window_moving_average:
          window_size: 5
          send_every: 1
    web_server:
      sorting_group_id: grp_extras

  - platform: esp32_touch
    name: "Button 2 Touch Value"
    pin: GPIO11
    id: touch_value_2
    filters:
      - median:
          window_size: 7  # More samples for stability
          send_every: 5
      - sliding_window_moving_average:
          window_size: 5
          send_every: 1
    web_server:
      sorting_group_id: grp_extras

  - platform: esp32_touch
    name: "Button 3 Touch Value"
    pin: GPIO12
    id: touch_value_3
    filters:
      - median:
          window_size: 7  # More samples for stability
          send_every: 5
      - sliding_window_moving_average:
          window_size: 5
          send_every: 1
    web_server:
      sorting_group_id: grp_extras

  - platform: esp32_touch
    name: "Button 4 Touch Value"
    pin: GPIO13
    id: touch_value_4
    filters:
      - median:
          window_size: 7  # More samples for stability
          send_every: 5
      - sliding_window_moving_average:
          window_size: 5
          send_every: 1
    web_server:
      sorting_group_id: grp_extras