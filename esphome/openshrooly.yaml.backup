esphome:
  name: openshrooly
  name_add_mac_suffix: true
  friendly_name: OpenShrooly
  project:
    name: grahamsz.openshrooly
    version: 0.2.3
  platformio_options:
    build_flags:
      - -Wno-cpp  # Suppress preprocessor warnings (including deprecation warnings)

  on_boot:
    priority: -10
    then:
      # Air exchange manager can run right away
      - script.execute: air_exchange_manager

      # Wait a couple seconds before programming
      - delay: 2s

      # Trigger the SWD programmer
      - swd_programmer.program: swd

      # Wait another 2 seconds for the programming task to complete
      - delay: 2s

      # Ensure the status sensor has updated to "Success"
      - wait_until:
          condition:
            lambda: 'return id(swd_programmer_status).state == "Success";'
          timeout: 10s

      # If still not success after timeout, log error
      - lambda: |-
          if (id(swd_programmer_status).state != "Success") {
            ESP_LOGE("boot", "SWD programming failed, continuing without coprocessor ready");
          }

      # Wait until humidity is valid
      - wait_until:
          condition:
            lambda: 'return !isnan(id(humidity).state);'
          timeout: 30s

      # Now run the humidity control manager
      - script.execute: humidity_control_manager

esp32:
  board: esp32-s3-devkitc-1
  framework:
    type: arduino

logger:
  level: INFO

api:
  reboot_timeout: 0s

ota:
  - platform: esphome


external_components:
  - source: 
      type: local
      path: external_components

wifi:
  ap:
    ssid: "OpenShrooly"
    manual_ip:
      static_ip: 192.168.4.1
      gateway: 192.168.4.1
      subnet: 255.255.255.0

  on_connect:
    then:
      - component.update: my_display   

captive_portal:

script:
  # This runs in a continuous loop (or when the timing is changed)
  - !include scripts/air_exchange_manager.yaml

  # This runs any time the humidity changes (usually once a second)
  - !include scripts/humidity_control_manager.yaml

  # This runs when the light values change or every 30 seconds
  - !include scripts/lighting_control_manager.yaml

  # One-time monitoring checks triggered by state changes
  - !include scripts/fan_rpm_check.yaml
  - !include scripts/fan_stop_check.yaml
  - !include scripts/humidifier_effectiveness_check.yaml

# Interval tasks
interval:
  # Update lighting every second
  - interval: 1s
    then:
      - script.execute: lighting_control_manager

  # Update display every 5 minutes
  - interval: 5min
    then:
      - component.update: my_display

# Additional interval tasks from separate files
  - !include scripts/time_debug.yaml        # Time logging (60s)
  - !include scripts/humidifier_resync.yaml # Humidifier I2C resync (60s)

# Global variables and state management
!include components/globals.yaml

# User controls and interface elements
!include components/controls.yaml

# Time synchronization
!include components/time.yaml

# Timezone selection and local time display
!include components/timezone.yaml

# Hardware components - split into logical sections
!include components/communication.yaml  # I2C, SPI, SWD
!include components/outputs.yaml        # LEDs, fans, buzzer
!include components/sensors.yaml        # All sensors
!include components/display.yaml        # E-paper display
!include components/buttons.yaml        # Physical and touch buttons

# Web server configuration
!include components/webserver.yaml


